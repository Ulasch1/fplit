// Fplit schema – M2+ models (User added; Groups, Expenses etc. come later)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String   @map("password_hash")
  name         String
  createdAt    DateTime @default(now()) @map("created_at")

  ownedGroups   Group[]          @relation("GroupOwner")
  memberships   GroupMember[]
  expensesPaid  Expense[]        @relation("ExpensePayer")
  expenseSplits ExpenseSplit[]   @relation("ExpenseSplitUser")
  paymentsFrom   Payment[]       @relation("PaymentFrom")
  paymentsTo     Payment[]       @relation("PaymentTo")
  notifications  Notification[]

  @@map("users")
}

enum GroupStatus {
  ACTIVE
  CLOSED
}

enum InviteLinkStatus {
  PENDING
  ACTIVE
  EXPIRED
}

model Group {
  id        String      @id @default(uuid())
  name      String
  ownerId   String      @map("owner_id")
  status    GroupStatus @default(ACTIVE)
  createdAt DateTime    @default(now()) @map("created_at")

  owner   User          @relation("GroupOwner", fields: [ownerId], references: [id])
  members       GroupMember[]
  inviteLinks   InviteLink[]
  expenses      Expense[]
  payments      Payment[]

  @@map("groups")
}

model GroupMember {
  groupId  String   @map("group_id")
  userId   String   @map("user_id")
  joinedAt DateTime @default(now()) @map("joined_at")

  group Group @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id])

  @@id([groupId, userId])
  @@map("group_members")
}

model InviteLink {
  id          String           @id @default(uuid())
  groupId     String           @map("group_id")
  token       String           @unique
  status      InviteLinkStatus @default(PENDING)
  createdAt   DateTime         @default(now()) @map("created_at")
  activatedAt DateTime?        @map("activated_at")

  group Group @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@map("invite_links")
}

model Expense {
  id          String   @id @default(uuid())
  groupId     String   @map("group_id")
  description String
  amountKurus Int      @map("amount_kurus")
  paidBy      String   @map("paid_by")
  createdAt   DateTime @default(now()) @map("created_at")

  group  Group          @relation(fields: [groupId], references: [id], onDelete: Cascade)
  payer  User           @relation("ExpensePayer", fields: [paidBy], references: [id])
  splits ExpenseSplit[]

  @@map("expenses")
}

model ExpenseSplit {
  id               String @id @default(uuid())
  expenseId        String @map("expense_id")
  userId           String @map("user_id")
  shareAmountKurus Int    @map("share_amount_kurus")

  expense Expense @relation(fields: [expenseId], references: [id], onDelete: Cascade)
  user    User    @relation("ExpenseSplitUser", fields: [userId], references: [id])

  @@unique([expenseId, userId])
  @@map("expense_splits")
}

enum PaymentStatus {
  PENDING_CONFIRMATION
  CONFIRMED
  REJECTED
}

enum RejectionReason {
  FORGOT
  WRONG_AMOUNT
  OTHER
}

enum NotificationType {
  SETTLEMENT_CONFIRMATION_REQUEST
}

model Payment {
  id              String          @id @default(uuid())
  groupId         String          @map("group_id")
  fromUser        String          @map("from_user")
  toUser          String          @map("to_user")
  amountKurus     Int             @map("amount_kurus")
  status          PaymentStatus   @default(PENDING_CONFIRMATION)
  createdAt       DateTime        @default(now()) @map("created_at")
  confirmedAt     DateTime?       @map("confirmed_at")
  rejectionReason RejectionReason? @map("rejection_reason")
  rejectionNote   String?         @map("rejection_note")

  group         Group          @relation(fields: [groupId], references: [id], onDelete: Cascade)
  payer         User           @relation("PaymentFrom", fields: [fromUser], references: [id])
  payee         User           @relation("PaymentTo", fields: [toUser], references: [id])
  notifications Notification[]

  @@map("payments")
}

model Notification {
  id               String           @id @default(uuid())
  userId           String           @map("user_id")
  type             NotificationType
  relatedPaymentId String           @map("related_payment_id")
  isRead           Boolean          @default(false) @map("is_read")
  createdAt        DateTime         @default(now()) @map("created_at")

  user    User    @relation(fields: [userId], references: [id])
  payment Payment @relation(fields: [relatedPaymentId], references: [id], onDelete: Cascade)

  @@map("notifications")
}
